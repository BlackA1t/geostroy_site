{
  "name": "geostroy-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run start:dev -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "prisma:generate:backend": "npm run prisma:generate -w backend",
    "prisma:validate:backend": "npm run prisma:validate -w backend"
  }
}
