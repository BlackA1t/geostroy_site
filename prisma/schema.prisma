generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         Role      @default(USER)
  requests     Request[]
  sessions     Session[]
  claimedGuestRequests GuestRequest[] @relation("GuestRequestClaimedBy")
  statusChanges RequestStatusHistory[]
  notifications Notification[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Request {
  id          String        @id @default(cuid())
  requestNumber Int         @unique @default(autoincrement())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  phone       String
  email       String?
  serviceType String
  material    String?
  quantity    String?
  description String
  status      RequestStatus @default(NEW)
  files       RequestFile[]
  statusHistory RequestStatusHistory[]
  notifications Notification[]
  sourceGuestRequests GuestRequest[] @relation("GuestRequestConversion")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GuestRequest {
  id                 String        @id @default(cuid())
  name               String
  phone              String
  email              String?
  serviceType        String
  material           String?
  quantity           String?
  description        String
  status             RequestStatus @default(NEW)
  claimTokenHash     String?       @unique
  claimedById        String?
  claimedBy          User?         @relation("GuestRequestClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  convertedRequestId String?
  convertedRequest   Request?      @relation("GuestRequestConversion", fields: [convertedRequestId], references: [id], onDelete: SetNull)
  files              GuestRequestFile[]
  statusHistory      RequestStatusHistory[]
  claimedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model RequestFile {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String?
  originalName String?
  sizeBytes Int?
  createdAt DateTime @default(now())
}

model GuestRequestFile {
  id             String       @id @default(cuid())
  guestRequestId String
  guestRequest   GuestRequest @relation(fields: [guestRequestId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String
  fileType       String?
  originalName   String?
  sizeBytes      Int?
  createdAt      DateTime     @default(now())
}

model RequestStatusHistory {
  id             String         @id @default(cuid())
  requestId      String?
  request        Request?       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  guestRequestId String?
  guestRequest   GuestRequest?  @relation(fields: [guestRequestId], references: [id], onDelete: Cascade)
  oldStatus      RequestStatus?
  newStatus      RequestStatus
  comment        String?
  changedById    String?
  changedBy      User?          @relation(fields: [changedById], references: [id], onDelete: SetNull)
  actorType      String
  createdAt      DateTime       @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String?
  request   Request?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model CallbackRequest {
  id        String         @id @default(cuid())
  name      String?
  phone     String
  status    CallbackStatus @default(NEW)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  NEED_INFO
  CALCULATED
  COMPLETED
  CANCELLED
}

enum CallbackStatus {
  NEW
  CONTACTED
  CANCELLED
}
